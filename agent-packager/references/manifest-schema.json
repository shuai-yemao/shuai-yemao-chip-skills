{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/chip-embedded/agent-packager/manifest-schema.json",
  "title": "Agent Package Manifest",
  "description": "标准化 Agent Package 元数据格式，任何 AI 编码工具（CherryStudio/Cline/Continue/Windsurf）均可解析",
  "type": "object",
  "required": [
    "schemaVersion", "name", "version", "type", "description",
    "createdAt", "skills", "entryPoints"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Manifest schema 版本号"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9\\-._]*$",
      "description": "包名称（小写字母数字连字符）"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "语义化版本号 (semver)"
    },
    "type": {
      "type": "string",
      "enum": ["embedded-agent", "general-agent", "skill-pack"],
      "description": "包类型"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "包描述"
    },
    "author": {
      "type": "string",
      "description": "作者/维护者"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "创建时间 (ISO 8601)"
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "platforms": {
          "type": "array",
          "items": { "type": "string", "enum": ["windows", "linux", "macos"] },
          "description": "支持的操作系统"
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["cherrystudio", "continue", "windsurf", "cursor", "claude-code"]
          },
          "description": "支持的目标宿主工具"
        },
        "minPythonVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+$",
          "description": "最低 Python 版本要求"
        }
      },
      "required": ["platforms", "hosts"]
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "tools": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "version": { "type": "string", "description": "版本要求" },
              "required": { "type": "boolean", "default": true },
              "description": { "type": "string" },
              "platform": { "type": "string", "description": "特定平台才需要" }
            }
          }
        },
        "mcpServers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "required": { "type": "boolean", "default": false },
              "description": { "type": "string" }
            }
          }
        },
        "externalTools": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "required": { "type": "boolean", "default": false },
              "platform": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "skills": {
      "type": "object",
      "required": ["total", "categories"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "categories": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "required": {
          "type": "array",
          "items": { "type": "string" },
          "description": "核心必备 skill（安装时必须激活）"
        },
        "optional": {
          "type": "array",
          "items": { "type": "string" },
          "description": "可选 skill（按需启用）"
        }
      }
    },
    "workflow": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "pipelines": { "type": "integer", "minimum": 0 },
        "agents": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "entryPoints": {
      "type": "object",
      "properties": {
        "SOUL.md": { "type": "string" },
        "workflowCoordinator": { "type": "string" },
        "primarySkill": { "type": "string" }
      },
      "required": ["SOUL.md"]
    },
    "hostConfig": {
      "type": "object",
      "description": "目标工具特定的配置占位符（安装时填入）"
    },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "date", "changes"],
        "properties": {
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "date": { "type": "string", "format": "date" },
          "changes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
